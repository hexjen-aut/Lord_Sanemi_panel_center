<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Sanemi OS — Centre de Commandement</title>
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Sans:wght@300;400;500&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet">
<script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
<style>
:root{--orange:#FF6A00;--od:#cc5200;--og:rgba(255,106,0,0.12);--og2:rgba(255,106,0,0.06);--black:#0a0a0a;--s1:#111111;--s2:#1a1a1a;--s3:#242424;--bd:rgba(255,255,255,0.07);--bd2:rgba(255,255,255,0.13);--tx:#f0ede8;--txm:#888880;--txd:#444440;--green:#4ade80;--red:#f87171;--amber:#fbbf24;--blue:#60a5fa;--teal:#2dd4bf;--purple:#a78bfa;--fd:'Syne',sans-serif;--fb:'DM Sans',sans-serif;--fm:'DM Mono',monospace;--r:10px;--rl:16px}
*{box-sizing:border-box;margin:0;padding:0}
body{background:var(--black);color:var(--tx);font-family:var(--fb);font-size:14px;line-height:1.6;min-height:100vh;overflow-x:hidden}
.app{display:flex;flex-direction:column;min-height:100vh}
.auth-screen{display:flex;align-items:center;justify-content:center;min-height:100vh;padding:24px}
.auth-box{background:var(--s1);border:.5px solid var(--bd2);border-radius:var(--rl);padding:40px;width:100%;max-width:400px;text-align:center}
.auth-logo{width:52px;height:52px;border-radius:12px;background:var(--orange);display:flex;align-items:center;justify-content:center;font-family:var(--fd);font-weight:800;font-size:24px;color:#000;margin:0 auto 20px}
.auth-title{font-family:var(--fd);font-weight:800;font-size:26px;margin-bottom:6px}
.auth-sub{font-size:13px;color:var(--txm);margin-bottom:28px}
.ai{width:100%;background:var(--s2);border:.5px solid var(--bd2);color:var(--tx);border-radius:var(--r);padding:12px 16px;font-family:var(--fb);font-size:14px;outline:none;margin-bottom:12px;transition:border-color .15s}
.ai:focus{border-color:var(--orange)}
.ab{width:100%;padding:12px;border-radius:var(--r);border:none;background:var(--orange);color:#000;font-family:var(--fd);font-weight:700;font-size:15px;cursor:pointer;transition:background .15s}
.ab:hover{background:var(--od);color:#fff}
.auth-msg{font-size:13px;color:var(--txm);margin-top:14px;line-height:1.5}
.topbar{display:flex;align-items:center;justify-content:space-between;padding:12px 24px;border-bottom:.5px solid var(--bd);background:rgba(10,10,10,0.92);backdrop-filter:blur(12px);position:sticky;top:0;z-index:100;flex-wrap:wrap;gap:8px}
.brand{display:flex;align-items:center;gap:10px}
.bm{width:30px;height:30px;border-radius:8px;background:var(--orange);display:flex;align-items:center;justify-content:center;font-family:var(--fd);font-weight:800;font-size:15px;color:#000}
.bn{font-family:var(--fd);font-weight:700;font-size:14px}
.bs{font-size:10px;color:var(--txm);font-family:var(--fm)}
.topnav{display:flex;gap:3px;flex-wrap:wrap}
.nb{padding:6px 12px;border-radius:6px;border:.5px solid transparent;background:transparent;color:var(--txm);cursor:pointer;font-family:var(--fb);font-size:13px;transition:all .15s;white-space:nowrap}
.nb:hover{background:var(--s2);color:var(--tx)}
.nb.active{background:var(--og);border-color:var(--orange);color:var(--orange)}
.topright{display:flex;align-items:center;gap:10px}
.topdate{font-family:var(--fm);font-size:11px;color:var(--txm)}
.avatar{width:30px;height:30px;border-radius:50%;background:var(--og);border:1px solid var(--orange);display:flex;align-items:center;justify-content:center;font-family:var(--fd);font-weight:700;font-size:12px;color:var(--orange);cursor:pointer}
.content{flex:1;padding:24px;max-width:1400px;margin:0 auto;width:100%}
.section{display:none;animation:fi .2s ease}
.section.active{display:block}
@keyframes fi{from{opacity:0;transform:translateY(5px)}to{opacity:1;transform:translateY(0)}}
.g2{display:grid;grid-template-columns:1fr 1fr;gap:14px}
.g3{display:grid;grid-template-columns:1fr 1fr 1fr;gap:14px}
.g4{display:grid;grid-template-columns:repeat(4,1fr);gap:12px}
.card{background:var(--s1);border:.5px solid var(--bd);border-radius:var(--rl);padding:18px}
.card-o{border-color:rgba(255,106,0,.25);background:linear-gradient(135deg,var(--og2) 0%,var(--s1) 60%)}
.ct{font-family:var(--fd);font-weight:700;font-size:11px;text-transform:uppercase;letter-spacing:.08em;color:var(--txm);margin-bottom:12px}
.ch{font-family:var(--fd);font-weight:700;font-size:19px}
.b{display:inline-flex;align-items:center;padding:2px 8px;border-radius:4px;font-size:11px;font-family:var(--fm)}
.bo{background:var(--og);color:var(--orange);border:.5px solid rgba(255,106,0,.3)}
.bg{background:rgba(74,222,128,.1);color:var(--green);border:.5px solid rgba(74,222,128,.3)}
.ba{background:rgba(251,191,36,.1);color:var(--amber);border:.5px solid rgba(251,191,36,.3)}
.br{background:rgba(248,113,113,.1);color:var(--red);border:.5px solid rgba(248,113,113,.3)}
.bb{background:rgba(96,165,250,.1);color:var(--blue);border:.5px solid rgba(96,165,250,.3)}
.bt{background:rgba(45,212,191,.1);color:var(--teal);border:.5px solid rgba(45,212,191,.3)}
.bp{background:rgba(167,139,250,.1);color:var(--purple);border:.5px solid rgba(167,139,250,.3)}
.bd2c{background:var(--s2);color:var(--txm);border:.5px solid var(--bd)}
.dv{height:.5px;background:var(--bd);margin:14px 0}
input,select,textarea{background:var(--s2);border:.5px solid var(--bd2);color:var(--tx);border-radius:var(--r);padding:8px 12px;font-family:var(--fb);font-size:13px;outline:none;transition:border-color .15s}
input:focus,select:focus,textarea:focus{border-color:var(--orange)}
input::placeholder{color:var(--txd)}
textarea{resize:vertical}
select option{background:var(--s2)}
.btn{padding:8px 16px;border-radius:var(--r);border:.5px solid var(--bd2);background:var(--s2);color:var(--tx);cursor:pointer;font-family:var(--fb);font-size:13px;transition:all .15s}
.btn:hover{background:var(--s3)}
.btn-o{background:var(--orange);border-color:var(--orange);color:#000;font-weight:600}
.btn-o:hover{background:var(--od);color:#fff}
.btn-sm{padding:4px 10px;font-size:12px}
.btn-ghost{background:transparent;border-color:transparent;color:var(--txm)}
.btn-ghost:hover{background:var(--s2);color:var(--tx);border-color:var(--bd)}
.pb{height:4px;border-radius:2px;background:var(--s3);overflow:hidden}
.pf{height:100%;border-radius:2px;background:var(--orange);transition:width .4s ease}
.pf-g{background:var(--green)}
.pf-a{background:var(--amber)}
.ti{display:flex;align-items:flex-start;gap:9px;padding:9px 0;border-bottom:.5px solid var(--bd)}
.ti:last-child{border-bottom:none}
.tc{width:17px;height:17px;border-radius:4px;border:1.5px solid var(--bd2);background:transparent;cursor:pointer;flex-shrink:0;margin-top:1px;transition:all .15s;display:flex;align-items:center;justify-content:center}
.tc.done{background:var(--green);border-color:var(--green)}
.tc.done::after{content:'✓';font-size:9px;color:#000;font-weight:700}
.wg{display:grid;grid-template-columns:repeat(7,1fr);gap:6px}
.dc{background:var(--s1);border:.5px solid var(--bd);border-radius:var(--r);overflow:hidden}
.dc.today{border-color:rgba(255,106,0,.4)}
.dh{padding:7px 9px;font-family:var(--fd);font-weight:700;font-size:10px;text-transform:uppercase;letter-spacing:.06em;border-bottom:.5px solid var(--bd)}
.dh.today{color:var(--orange)}
.de{padding:6px;min-height:60px;display:flex;flex-direction:column;gap:3px}
.dev{padding:3px 6px;border-radius:4px;font-size:10px;border-left:2px solid var(--orange);background:var(--og2)}
.dev.wenna{border-color:var(--orange)}
.dev.myria{border-color:var(--teal);background:rgba(45,212,191,.06)}
.dev.hexjen{border-color:var(--blue);background:rgba(96,165,250,.06)}
.dev.perso{border-color:var(--amber);background:rgba(251,191,36,.06)}
.dev.fixi{border-color:var(--purple);background:rgba(167,139,250,.06)}
.pt{width:100%;border-collapse:collapse}
.pt th{text-align:left;font-family:var(--fd);font-weight:700;font-size:10px;text-transform:uppercase;letter-spacing:.08em;color:var(--txm);padding:7px 10px;border-bottom:.5px solid var(--bd)}
.pt td{padding:10px;border-bottom:.5px solid var(--bd);font-size:13px;vertical-align:middle}
.pt tr:last-child td{border-bottom:none}
.pt tr:hover td{background:var(--s2)}
.rc{background:var(--s2);border:.5px solid var(--bd);border-radius:var(--r);padding:12px 14px;margin-bottom:8px}
.rt{font-family:var(--fd);font-weight:700;font-size:12px;margin-bottom:3px}
.rd{font-size:11px;color:var(--txm);line-height:1.5}
.fs{display:flex;gap:10px;align-items:flex-start;padding:10px 0;border-bottom:.5px solid var(--bd)}
.fs:last-child{border-bottom:none}
.fn{width:24px;height:24px;border-radius:50%;background:var(--og);border:1px solid rgba(255,106,0,.4);color:var(--orange);font-family:var(--fm);font-size:10px;display:flex;align-items:center;justify-content:center;flex-shrink:0;margin-top:2px}
.ft{font-weight:500;font-size:13px}
.fs2{font-size:11px;color:var(--txm);margin-top:1px}
.mo{display:none;position:fixed;inset:0;background:rgba(0,0,0,.82);backdrop-filter:blur(6px);z-index:200;align-items:center;justify-content:center;padding:16px}
.mo.open{display:flex}
.mbox{background:var(--s1);border:.5px solid var(--bd2);border-radius:var(--rl);padding:22px;width:100%;max-width:500px;max-height:88vh;overflow-y:auto;position:relative}
.mt{font-family:var(--fd);font-weight:700;font-size:17px;margin-bottom:14px}
.mc2{position:absolute;top:14px;right:14px}
.fl{display:block;font-size:11px;color:var(--txm);text-transform:uppercase;letter-spacing:.06em;font-family:var(--fm);margin-bottom:4px}
.fr{margin-bottom:11px}
.fr input,.fr select,.fr textarea{width:100%}
.fr2{display:grid;grid-template-columns:1fr 1fr;gap:9px}
.nf{position:fixed;bottom:20px;right:20px;z-index:300;background:var(--s1);border:.5px solid var(--orange);border-radius:var(--r);padding:11px 15px;font-size:13px;max-width:280px;transform:translateY(70px);opacity:0;transition:all .3s}
.nf.show{transform:translateY(0);opacity:1}
.chip{padding:6px 14px;border-radius:20px;cursor:pointer;font-size:12px;border:.5px solid var(--bd2);background:var(--s2);color:var(--txm);transition:all .15s;white-space:nowrap}
.chip:hover,.chip.active{background:var(--og);border-color:var(--orange);color:var(--orange)}
.sc{background:var(--s2);border:.5px solid var(--bd);border-radius:var(--rl);padding:14px;transition:border-color .2s}
.sc:hover{border-color:var(--bd2)}
.sn{font-family:var(--fd);font-weight:700;font-size:14px;margin-bottom:4px}
.sd{font-size:12px;color:var(--txm);margin-bottom:9px;line-height:1.5}
.je{background:var(--s2);border:.5px solid var(--bd);border-radius:var(--rl);padding:16px;margin-bottom:10px}
.jd{font-family:var(--fm);font-size:11px;color:var(--txm);margin-bottom:10px}
.jl{font-size:11px;color:var(--txm);font-family:var(--fm);text-transform:uppercase;letter-spacing:.06em;margin-bottom:3px}
.ic{background:var(--s2);border:.5px solid var(--bd);border-radius:var(--rl);padding:16px;transition:border-color .2s;position:relative}
.ic:hover{border-color:var(--bd2)}
.ic.starred{border-color:rgba(251,191,36,.4);background:rgba(251,191,36,.03)}
.ii{width:100%;height:130px;object-fit:cover;border-radius:8px;margin-bottom:10px}
.it{font-family:var(--fd);font-weight:700;font-size:14px;margin-bottom:4px}
.rim{display:flex;align-items:center;gap:10px;padding:10px;background:var(--s2);border:.5px solid var(--bd);border-radius:var(--r);margin-bottom:6px}
.ric{width:32px;height:32px;border-radius:8px;background:var(--og);display:flex;align-items:center;justify-content:center;font-size:14px;flex-shrink:0}
.sh{display:flex;align-items:center;justify-content:space-between;margin-bottom:18px}
.st{font-family:var(--fd);font-weight:800;font-size:22px}
.ss{font-size:12px;color:var(--txm);margin-top:2px}
.mvb{background:var(--s2);border-radius:var(--r);padding:12px 14px;display:flex;align-items:center;justify-content:space-between;gap:14px;margin-bottom:14px}
.mvd{width:10px;height:10px;border-radius:50%;background:var(--s3);cursor:pointer;transition:background .1s}
.mvd.lit{background:var(--orange)}
.tb2{display:flex;gap:9px;align-items:stretch;margin-bottom:5px}
.tl{font-family:var(--fm);font-size:10px;color:var(--txd);width:36px;text-align:right;padding-top:7px;flex-shrink:0}
.te{flex:1;padding:6px 11px;border-radius:6px;border-left:2px solid var(--orange);background:var(--og2);font-size:12px}
.te.myria{border-color:var(--teal);background:rgba(45,212,191,.06)}
.te.hexjen{border-color:var(--blue);background:rgba(96,165,250,.06)}
.te.perso{border-color:var(--amber);background:rgba(251,191,36,.06)}
.loader{display:flex;align-items:center;justify-content:center;padding:32px;color:var(--txm);font-size:13px;font-family:var(--fm)}
.spin{display:inline-block;width:14px;height:14px;border:2px solid var(--s3);border-top-color:var(--orange);border-radius:50%;animation:sp .6s linear infinite;margin-right:8px}
@keyframes sp{to{transform:rotate(360deg)}}
.empty{text-align:center;padding:28px;color:var(--txd);font-size:13px}
.ua{border:1.5px dashed var(--bd2);border-radius:var(--r);padding:20px;text-align:center;cursor:pointer;transition:border-color .15s;color:var(--txm);font-size:13px}
.ua:hover,.ua.drag{border-color:var(--orange);color:var(--tx)}
::-webkit-scrollbar{width:3px;height:3px}
::-webkit-scrollbar-thumb{background:var(--s3);border-radius:2px}
@media(max-width:900px){.g3{grid-template-columns:1fr 1fr}.g4{grid-template-columns:1fr 1fr}.wg{grid-template-columns:repeat(4,1fr)}}
</style>
</head>
<body>
<div class="app">

<!-- AUTH -->
<div id="authScreen" class="auth-screen">
  <div class="auth-box">
    <div class="auth-logo">S</div>
    <div class="auth-title">Sanemi OS</div>
    <div class="auth-sub">Centre de commandement personnel</div>
    <div class="fr" style="text-align:left">
      <label class="fl" style="display:block;margin-bottom:4px">Email</label>
      <input type="email" id="authEmail" class="ai" placeholder="hanamisama74@gmail.com" style="margin-bottom:0">
    </div>
    <div class="fr" style="text-align:left;margin-top:10px;position:relative">
      <label class="fl" style="display:block;margin-bottom:4px">Mot de passe</label>
      <input type="password" id="authPwd" class="ai" placeholder="••••••••••" style="margin-bottom:0;padding-right:44px" onkeydown="if(event.key==='Enter')signIn()">
      <button onclick="togglePwd()" style="position:absolute;right:12px;bottom:10px;background:none;border:none;cursor:pointer;color:var(--txm);font-size:16px" id="eyeBtn">👁</button>
    </div>
    <div id="authMsg" style="font-size:12px;color:var(--red);margin:8px 0;min-height:18px;text-align:left"></div>
    <button class="ab" id="signInBtn" onclick="signIn()">Accéder au dashboard →</button>
    <div style="margin-top:16px;font-size:11px;color:var(--txd)">Accès privé · Sanemi OS v2</div>
  </div>
</div>

<!-- MAIN APP -->
<div id="mainApp" style="display:none">
<header class="topbar">
  <div class="brand"><div class="bm">S</div><div><div class="bn">Sanemi OS</div><div class="bs">Centre de commandement</div></div></div>
  <nav class="topnav">
    <button class="nb active" onclick="showSec('planning',this)">Planning</button>
    <button class="nb" onclick="showSec('projets',this)">Projets</button>
    <button class="nb" onclick="showSec('finance',this)">Finance</button>
    <button class="nb" onclick="showSec('idees',this)">Idées</button>
    <button class="nb" onclick="showSec('journal',this)">Journal</button>
    <button class="nb" onclick="showSec('sorties',this)">Sorties</button>
    <button class="nb" onclick="showSec('rappels',this)">Rappels</button>
  </nav>
  <div class="topright">
    <div class="topdate" id="topDate"></div>
    <div class="avatar" id="av" onclick="signOut()" title="Déconnexion">S</div>
  </div>
</header>
<main class="content">

<!-- PLANNING -->
<section class="section active" id="planning">
  <div class="sh">
    <div><div class="st">Planning Semaine</div><div class="ss">Semaine <span id="wkNum"></span> · Mode : <span id="modeLabel">Alterné</span></div></div>
    <div style="display:flex;gap:8px;align-items:center">
      <span class="b ba">🔥 <span id="streakVal">0</span>j streak</span>
      <button class="btn btn-sm" onclick="openM('mTask')">+ Tâche</button>
    </div>
  </div>
  <div class="mvb">
    <div><div style="font-size:13px;font-weight:500">Niveau d'énergie</div><div style="font-size:11px;color:var(--txm)">Adapte tes blocs de travail</div></div>
    <div>
      <div style="font-size:11px;color:var(--txm);text-align:right;margin-bottom:3px">Mode : <strong id="motive-lbl" style="color:var(--orange)">Équilibré</strong></div>
      <div style="display:flex;gap:4px" id="mvRow"><div class="mvd lit" onclick="setMv(1)"></div><div class="mvd lit" onclick="setMv(2)"></div><div class="mvd lit" onclick="setMv(3)"></div><div class="mvd" onclick="setMv(4)"></div><div class="mvd" onclick="setMv(5)"></div></div>
    </div>
  </div>
  <div class="card" style="margin-bottom:14px"><div class="ct">Cette semaine</div><div class="wg" id="weekGrid"></div></div>
  <div class="g2">
    <div class="card">
      <div class="ct">Tâches du jour — <span id="todayLbl"></span></div>
      <div id="todayTasks"><div class="loader"><span class="spin"></span>Chargement...</div></div>
      <div style="margin-top:10px;display:flex;gap:8px">
        <input type="text" id="qTask" placeholder="Tâche rapide..." style="flex:1" onkeydown="if(event.key==='Enter')addQTask()">
        <button class="btn btn-sm btn-o" onclick="addQTask()">+</button>
      </div>
    </div>
    <div class="card"><div class="ct">Blocs suggérés</div><div id="timeBlocks"></div></div>
  </div>
</section>

<!-- PROJETS -->
<section class="section" id="projets">
  <div class="sh"><div><div class="st">Projets</div><div class="ss">Priorités & objectifs</div></div><button class="btn btn-sm btn-o" onclick="openM('mObj')">+ Objectif</button></div>
  <div class="card" style="margin-bottom:14px">
    <div class="ct">Tableau de priorités</div>
    <div id="prioLoader" class="loader"><span class="spin"></span>Chargement...</div>
    <table class="pt" id="prioTable" style="display:none"><thead><tr><th>#</th><th>Projet</th><th>Focus</th><th>Urgence</th><th>Avancement</th><th>Statut</th></tr></thead><tbody id="prioBody"></tbody></table>
  </div>
  <div class="g2" id="projCards"></div>
</section>

<!-- FINANCE -->
<section class="section" id="finance">
  <div class="sh"><div><div class="st">Finance</div><div class="ss">MAD · Casablanca</div></div><div style="display:flex;gap:8px"><button class="btn btn-sm" onclick="openM('mRev')">+ Revenu</button><button class="btn btn-sm" onclick="openM('mDep')">+ Dépense</button></div></div>
  <div class="g4" style="margin-bottom:14px">
    <div class="card card-o"><div class="ct">Revenus MAD</div><div style="font-family:var(--fd);font-weight:700;font-size:24px;color:var(--orange)" id="totRev">0 MAD</div></div>
    <div class="card"><div class="ct">Dépenses</div><div style="font-family:var(--fd);font-weight:700;font-size:24px" id="totDep">0 MAD</div></div>
    <div class="card"><div class="ct">Épargne (15%)</div><div style="font-family:var(--fd);font-weight:700;font-size:24px;color:var(--green)" id="totEp">0 MAD</div></div>
    <div class="card"><div class="ct">Disponible</div><div style="font-family:var(--fd);font-weight:700;font-size:24px;color:var(--teal)" id="totDis">0 MAD</div></div>
  </div>
  <div class="g2" style="margin-bottom:14px">
    <div class="card">
      <div class="ct">Règles 50/30/15/5</div>
      <div class="rc"><div class="rt">🏠 Besoins — 50%</div><div class="rd">Loyer, nourriture, transport, téléphone</div><div class="pb" style="margin-top:7px"><div class="pf pf-g" id="b-bes" style="width:0%"></div></div><div style="font-size:11px;color:var(--txm);margin-top:3px" id="v-bes">— MAD</div></div>
      <div class="rc"><div class="rt">📈 Projets — 30%</div><div class="rd">WennaShop, Myria, Hexjen, outils</div><div class="pb" style="margin-top:7px"><div class="pf" id="b-proj" style="width:0%"></div></div><div style="font-size:11px;color:var(--txm);margin-top:3px" id="v-proj">— MAD</div></div>
