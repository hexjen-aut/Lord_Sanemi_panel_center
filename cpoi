function selMood(el,m){document.querySelectorAll('#moodSel .chip').forEach(c=>c.classList.remove('active')); el.classList.add('active'); curMood=m;}
function selBud(el,v){document.querySelectorAll('#budgetSel .chip').forEach(c=>c.classList.remove('active')); el.classList.add('active'); curBudget=v;}
function genSorties() {
  if(!curMood){notify('Choisis une humeur !');return;}
  const pool=SRTDB[curMood]||{}; let res=[];
  for(let b=0;b<=curBudget;b++) if(pool[b]) res=res.concat(pool[b]);
  if(!res.length){document.getElementById('sortieRes').innerHTML='<div class="empty">Essaie un autre filtre</div>';return;}
  document.getElementById('sortieRes').innerHTML=`<div class="g2">${res.map(s=>`<div class="sc"><div style="font-family:var(--fm);font-size:10px;color:var(--txm);text-transform:uppercase;letter-spacing:.08em;margin-bottom:5px">${s.q}</div><div class="sn">${s.n}</div><div class="sd">${s.d}</div><div style="display:flex;justify-content:space-between;align-items:center"><span class="b bg" style="font-size:10px">${curBudget===0?'Gratuit':'Budget OK'}</span><button class="btn btn-ghost btn-sm" onclick="likeSortie('${s.n}')">♡</button></div></div>`).join('')}</div>`;
}
async function likeSortie(name) {
  if(sb&&currentUser){const {data:p}=await sb.from('sanemi_sortie_prefs').select('*').eq('user_id',currentUser.id).limit(1).maybeSingle(); const liked=p?.liked_places||[]; if(!liked.includes(name)){const nl=[...liked,name]; if(p) await sb.from('sanemi_sortie_prefs').update({liked_places:nl,updated_at:new Date().toISOString()}).eq('id',p.id); else await sb.from('sanemi_sortie_prefs').insert({user_id:currentUser.id,liked_places:nl}); renderPref(nl);}else renderPref(liked);}
  notify('♡ Sauvegardé');
}
function renderPref(liked) { document.getElementById('prefProfile').innerHTML=liked.length?`<div style="display:flex;flex-wrap:wrap;gap:6px">${liked.map(l=>`<span class="b bt" style="font-size:11px">${l}</span>`).join('')}</div>`:'<div style="font-size:12px;color:var(--txm)">Marque des lieux ♡</div>'; }

