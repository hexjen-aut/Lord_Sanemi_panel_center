}
async function saveJournal() {
  const entry={date:todayStr(),humeur:jH,energie_demain:jE,realisations:document.getElementById('jReal').value,blocages:document.getElementById('jBlock').value,idee_du_jour:document.getElementById('jIdee').value,note_libre:document.getElementById('jNote').value};
  if(sb) await sb.from('sanemi_journal').upsert({...entry, user_id: currentUser?.id},{onConflict:'user_id,date'});
