  let custom=[];
  const {data:objData, error:objErr}=await sb.from('sanemi_objectives').select('*').eq('user_id', currentUser?.id).order('created_at',{ascending:false}); if(!objErr) custom=objData||[];
  renderPrio(custom); renderProjCards(custom);
}
function renderPrio(custom) {
  document.getElementById('prioLoader').style.display='none'; document.getElementById('prioTable').style.display='table';
  const uc={critique:'br',haute:'bo',normale:'ba'};
  const rows=BASE_PROJS.map((p,i)=>`<tr><td><span style="font-family:var(--fm);color:var(--txm)">#${i+1}</span></td><td><strong style="font-family:var(--fd)">${p.name}</strong></td><td style="color:var(--txm);font-size:12px">${p.focus}</td><td><span class="b ${uc[p.urg]||'bd2c'}">${p.urg}</span></td><td style="min-width:90px"><div class="pb" style="margin-bottom:2px"><div class="pf" style="width:${p.prog}%"></div></div><span style="font-size:11px;color:var(--txm)">${p.prog}%</span></td><td><span class="b ${p.stat==='Pause'?'bd2c':'bg'}">${p.stat}</span></td></tr>`).join('');
  const crows=custom.map(o=>`<tr><td><span style="font-family:var(--fm);color:var(--txd)">+</span></td><td>${pName(o.project)}</td><td style="color:var(--txm);font-size:12px">${o.title}</td><td><span class="b ${uc[o.urgence]||'bd2c'}">${o.urgence}</span></td><td style="min-width:90px"><div class="pb" style="margin-bottom:2px"><div class="pf" style="width:${o.progress}%"></div></div><span style="font-size:11px;color:var(--txm)">${o.progress}%</span></td><td><span class="b bb">${o.deadline||'—'}</span></td></tr>`).join('');
  document.getElementById('prioBody').innerHTML=rows+crows;
}
function renderProjCards(custom) {
  document.getElementById('projCards').innerHTML=BASE_PROJS.map(p=>{
    const myO=custom.filter(o=>o.project===p.key), myT=allTasks.filter(t=>t.project===p.key);
