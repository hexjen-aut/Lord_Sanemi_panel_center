  c.innerHTML=rems.map(r=>{const d=new Date(r.remind_at), past=d<now; return `<div class="rim${r.sent||past?' rem-sent':''}"><div class="ric">⏰</div><div style="flex:1"><div style="font-size:13px;font-weight:500">${r.title}</div><div style="display:flex;gap:5px;margin-top:3px"><span class="b bd2c" style="font-size:10px">📧 email</span><span class="b ${pColor(r.related_project)}" style="font-size:10px">${pName(r.related_project)}</span><span style="font-size:11px;color:var(--txd)">${d.toLocaleDateString('fr-FR',{day:'numeric',month:'short',hour:'2-digit',minute:'2-digit'})}</span></div></div><span class="b ${r.sent||past?'bg':'bo'}">${r.sent?'Envoyé':past?'Passé':'Programmé'}</span></div>`; }).join('');
}
async function saveRemind() {
  const title=document.getElementById('remTitle').value.trim(), dt=document.getElementById('remDate').value; if(!title||!dt) return;
  const r={title,message:document.getElementById('remMsg').value,remind_at:new Date(dt).toISOString(),channel:'email',related_project:document.getElementById('remProj').value,sent:false};
