// ══ FINANCE ══
async function loadTx() {
  const {data, error}=await sb.from('sanemi_transactions').select('*').eq('user_id', currentUser?.id).order('created_at',{ascending:false});
  if(error){console.error('loadTx:',error); renderFin([]); return;}
  renderFin(data||[]);
}
function renderFin(txs) {
  const rev=txs.filter(t=>t.type==='revenu').reduce((s,t)=>s+Number(t.amount),0);
  const dep=txs.filter(t=>t.type==='depense').reduce((s,t)=>s+Number(t.amount),0);
  const ep=Math.round(rev*.15), dis=Math.max(0,rev-dep);
  document.getElementById('totRev').textContent=rev.toLocaleString('fr-FR')+' MAD';
  document.getElementById('totDep').textContent=dep.toLocaleString('fr-FR')+' MAD';
  document.getElementById('totEp').textContent=ep.toLocaleString('fr-FR')+' MAD';
  document.getElementById('totDis').textContent=dis.toLocaleString('fr-FR')+' MAD';
  if(rev>0){[['bes',.5],['proj',.3],['ep',.15],['lib',.05]].forEach(([k,p])=>{const v=Math.round(rev*p); document.getElementById('b-'+k).style.width=(p*100)+'%'; document.getElementById('v-'+k).textContent=v.toLocaleString('fr-FR')+' MAD';});}
  const log=document.getElementById('txLog');
  if(!txs.length){log.innerHTML='<div class="empty">Aucune transaction</div>';return;}
  log.innerHTML=txs.slice(0,8).map(t=>`<div class="ti"><div style="flex:1"><div style="font-size:13px">${t.label||t.source||'—'}</div><div style="display:flex;gap:4px;margin-top:2px"><span class="b bd2c" style="font-size:10px">${t.category||t.rev_type||'—'}</span><span style="font-size:10px;color:var(--txd)">${new Date(t.created_at).toLocaleDateString('fr-FR')}</span></div></div><div style="font-family:var(--fm);font-size:13px;color:${t.type==='revenu'?'var(--green)':'var(--red)'};font-weight:500">${t.type==='revenu'?'+':'-'}${Number(t.amount).toLocaleString('fr-FR')} MAD</div></div>`).join('');
}
async function saveRevenu() {
  const amt=parseFloat(document.getElementById('rAmt').value), src=document.getElementById('rSrc').value.trim(); if(!amt||!src) return;
  const t={type:'revenu',label:src,source:src,amount:amt,rev_type:document.getElementById('rType').value,category:'revenu'};
  if(sb) await sb.from('sanemi_transactions').insert({...t, user_id: currentUser?.id});
  loadTx(); closeM('mRev'); document.getElementById('rAmt').value=''; document.getElementById('rSrc').value=''; notify('Revenu enregistré · Répartition calculée ✓');
}
async function saveDepense() {
  const amt=parseFloat(document.getElementById('dAmt').value), lbl=document.getElementById('dLabel').value.trim(); if(!amt||!lbl) return;
  const t={type:'depense',label:lbl,amount:amt,category:document.getElementById('dCat').value};
  if(sb) await sb.from('sanemi_transactions').insert({...t, user_id: currentUser?.id});
  loadTx(); closeM('mDep'); document.getElementById('dAmt').value=''; document.getElementById('dLabel').value=''; notify('Dépense enregistrée ✓');
}

// ══ IDÉES ══
async function loadIdeas() {
  document.getElementById('ideasLoader').style.display='flex'; document.getElementById('ideasGrid').style.display='none';
  const {data, error}=await sb.from('sanemi_ideas').select('*').eq('user_id', currentUser?.id).order('created_at',{ascending:false});
  if(error){console.error('loadIdeas:',error); renderIdeas([]); return;}
  allIdeas=data||[]; renderIdeas(allIdeas);
}
function renderIdeas(ideas) {
  const loader=document.getElementById('ideasLoader'), grid=document.getElementById('ideasGrid');
  loader.style.display='none';
  if(!ideas.length){grid.style.display='block'; grid.innerHTML='<div class="empty">Aucune idée capturée</div>'; return;}
  grid.style.display='grid';
  grid.innerHTML=ideas.map(i=>`<div class="ic${i.is_starred?' starred':''}"><div style="display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:4px">${i.image_url?`<img src="${i.image_url}" class="ii">`:''}</div><div style="display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:4px"><div class="it">${i.title}</div><button class="btn btn-ghost btn-sm" onclick="starIdea('${i.id}',${!i.is_starred})" style="padding:2px 6px;color:${i.is_starred?'var(--amber)':'var(--txd)'}">${i.is_starred?'⭐':'☆'}</button></div><div style="font-size:12px;color:var(--txm);line-height:1.5;margin-bottom:8px">${i.content||''}</div><div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:6px"><span class="b ${pColor(i.project)}" style="font-size:10px">${pName(i.project)}</span><span class="b ${i.status==='nouvelle'?'bo':i.status==='en_cours'?'bg':'bd2c'}" style="font-size:10px">${i.status}</span></div><div style="display:flex;flex-wrap:wrap;gap:4px">${(i.tags||[]).map(t=>`<span class="b bd2c" style="font-size:10px">${t}</span>`).join('')}</div><div style="font-size:10px;color:var(--txd);margin-top:6px">${new Date(i.created_at).toLocaleDateString('fr-FR')}</div></div>`).join('');
}
async function starIdea(id, val) {
  if(sb) await sb.from('sanemi_ideas').update({is_starred:val}).eq('id',id);
  const i=allIdeas.find(x=>x.id===id); if(i) i.is_starred=val; renderIdeas(allIdeas);
}
function filterI(proj, el) {
  document.querySelectorAll('#ideaFilters .chip').forEach(c=>c.classList.remove('active')); el.classList.add('active');
  if(proj==='all') renderIdeas(allIdeas);
  else if(proj==='starred') renderIdeas(allIdeas.filter(i=>i.is_starred));
  else renderIdeas(allIdeas.filter(i=>i.project===proj));
}
function prevImg(e) { const f=e.target.files[0]; if(!f) return; ideaImg=f; document.getElementById('uploadArea').innerHTML=`<img src="${URL.createObjectURL(f)}" style="width:100%;height:110px;object-fit:cover;border-radius:8px">`; }
function dropFile(e) { e.preventDefault(); e.currentTarget.classList.remove('drag'); const f=e.dataTransfer.files[0]; if(!f) return; ideaImg=f; document.getElementById('uploadArea').innerHTML=`<img src="${URL.createObjectURL(f)}" style="width:100%;height:110px;object-fit:cover;border-radius:8px">`; }
async function saveIdea() {
  const title=document.getElementById('iTitle').value.trim(); if(!title) return;
  let imgUrl=null;
  if(ideaImg&&sb&&currentUser){ const ext=ideaImg.name.split('.').pop(), path=`${currentUser.id}/${Date.now()}.${ext}`; const {data:up}=await sb.storage.from('ideas-images').upload(path,ideaImg); if(up){const {data:ud}=sb.storage.from('ideas-images').getPublicUrl(path); imgUrl=ud?.publicUrl;} }
  const idea={title,content:document.getElementById('iContent').value,project:document.getElementById('iProj').value,status:document.getElementById('iStatus').value,tags:document.getElementById('iTags').value.split(',').map(t=>t.trim()).filter(Boolean),image_url:imgUrl,is_starred:false};
  if(sb) await sb.from('sanemi_ideas').insert({...idea, user_id: currentUser?.id});
  loadIdeas(); closeM('mIdea'); ['iTitle','iContent','iTags'].forEach(id=>document.getElementById(id).value=''); ideaImg=null; document.getElementById('uploadArea').textContent='Clique ou glisse une image ici'; notify('Idée capturée ✓');
}

