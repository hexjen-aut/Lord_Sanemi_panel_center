// ══ DATE ══
function setTopDate() {
  const now = new Date();
  document.getElementById('topDate').textContent = now.toLocaleDateString('fr-FR',{weekday:'long',day:'numeric',month:'long'});
  document.getElementById('todayLbl').textContent = ['Lundi','Mardi','Mercredi','Jeudi','Vendredi','Samedi','Dimanche'][dow()];
  document.getElementById('wkNum').textContent = wkn(now);
}
function dow(){ return (new Date().getDay()+6)%7; }
function wkn(d){ const s=new Date(d.getFullYear(),0,1); return Math.ceil((((d-s)/86400000)+s.getDay()+1)/7); }
function todayStr(){ return new Date().toISOString().split('T')[0]; }

// ══ LOAD ALL ══
async function loadAll() {
  setTopDate(); buildWeek(); renderTimeBlocks();
  await Promise.all([loadTasks(), loadObjs(), loadTx(), loadIdeas(), loadJournal(), loadReminders()]);
}

// ══ TASKS ══
async function loadTasks() {
  if (!sb||!user) { renderTodayTasks([]); return; }
  const {data} = await sb.from('sanemi_tasks').select('*');
  allTasks = data||[];
  buildWeek();
  renderTodayTasks(allTasks.filter(t=>t.day_of_week===dow()));
}
function buildWeek() {
  const DAYS=['Lun','Mar','Mer','Jeu','Ven','Sam','Dim'], MODES=['Dev','Admin','Dev','Créa','Dev','Bilan','Repos'], today=dow();
  const g = document.getElementById('weekGrid'); g.innerHTML='';
  DAYS.forEach((d,i)=>{
    const tasks=allTasks.filter(t=>t.day_of_week===i), isT=i===today;
    const col=document.createElement('div'); col.className='dc'+(isT?' today':'');
    col.innerHTML=`<div class="dh${isT?' today':''}">${d}<span style="font-weight:400;font-size:9px;color:var(--txd);display:block">${MODES[i]}</span></div><div class="de" id="de${i}"></div>`;
    g.appendChild(col);
    const de=col.querySelector('#de'+i);
    if(!tasks.length) de.innerHTML='<div style="font-size:10px;color:var(--txd)">—</div>';
    tasks.forEach(t=>{ const e=document.createElement('div'); e.className=`dev ${t.project||'wenna'}`; e.textContent=t.title.substring(0,18)+(t.title.length>18?'…':''); de.appendChild(e); });
  });
}
function renderTodayTasks(tasks) {
  const c=document.getElementById('todayTasks');
  if(!tasks.length){c.innerHTML='<div class="empty">Aucune tâche aujourd\'hui</div>';return;}
  c.innerHTML=tasks.map(t=>`<div class="ti"><div class="tc${t.done?' done':''}" onclick="toggleT('${t.id}',${!t.done})"></div><div style="flex:1"><div style="font-size:13px${t.done?';text-decoration:line-through;color:var(--txm)':''}">${t.title}</div><div style="display:flex;gap:4px;margin-top:2px"><span class="b ${pColor(t.project)}" style="font-size:10px">${pName(t.project)}</span><span style="font-size:10px;color:var(--txd)">${t.duration||1}h</span></div></div><button class="btn btn-ghost btn-sm" onclick="delT('${t.id}')" style="padding:2px 6px;color:var(--txd)">✕</button></div>`).join('');
}
async function toggleT(id, done) {
  if(sb) await sb.from('sanemi_tasks').update({done}).eq('id',id);
  const t=allTasks.find(x=>x.id===id); if(t) t.done=done;
  renderTodayTasks(allTasks.filter(t=>t.day_of_week===dow()));
}
async function delT(id) {
  if(sb) await sb.from('sanemi_tasks').delete().eq('id',id);
  allTasks=allTasks.filter(x=>x.id!==id); buildWeek(); renderTodayTasks(allTasks.filter(t=>t.day_of_week===dow()));
}
async function addQTask() {
  const v=document.getElementById('qTask').value.trim(); if(!v) return;
  const t={title:v,project:'wenna',priority:'moyenne',day_of_week:dow(),duration:1,done:false,week_number:wkn(new Date()),year:new Date().getFullYear()};
  if(sb){const {data}=await sb.from('sanemi_tasks').insert({...t, user_id: currentUser?.id}).select().single(); if(data) allTasks.push(data);}
  else allTasks.push({...t,id:Date.now().toString()});
  document.getElementById('qTask').value=''; buildWeek(); renderTodayTasks(allTasks.filter(t=>t.day_of_week===dow()));
}
async function saveTask() {
  const title=document.getElementById('tTitle').value.trim(); if(!title) return;
  const t={title,project:document.getElementById('tProj').value,priority:document.getElementById('tPrio').value,day_of_week:parseInt(document.getElementById('tDay').value),duration:parseFloat(document.getElementById('tDur').value),done:false,week_number:wkn(new Date()),year:new Date().getFullYear()};
  if(sb){const {data}=await sb.from('sanemi_tasks').insert({...t, user_id: currentUser?.id}).select().single(); if(data) allTasks.push(data);}
  else allTasks.push({...t,id:Date.now().toString()});
  buildWeek(); renderTodayTasks(allTasks.filter(t=>t.day_of_week===dow()));
  closeM('mTask'); document.getElementById('tTitle').value=''; notify('Tâche ajoutée ✓');
}

// ══ OBJECTIVES ══
